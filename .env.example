# Environment Configuration for Shopping Assistant

# Copy this file to .env and fill in your actual values

# ============================================
# API Keys
# ============================================

# Google Gemini API (cho LLM extraction)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Alibaba DashScope / Qwen-compatible API
# OpenAI-compatible base URL:
# https://coding-intl.dashscope.aliyuncs.com/v1
ALIBABA_API_KEY=your_alibaba_api_key_here

# ============================================
# Database
# ============================================

# SQLite (development)
DATABASE_URL=sqlite:///./shopping.db

# PostgreSQL (production - uncomment if using)
# DATABASE_URL=postgresql://shopping:shopping123@localhost:5432/shopping_db

# ============================================
# API URLs
# ============================================

# Local development
BACKEND_URL=http://localhost:8000
AI_PIPELINE_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000
BACKEND_SCAN_API_URL=http://localhost:8000/api/scan
ENABLE_BACKEND_SYNC=false
SEED_MOCK_DATA=false

# Production (update after deployment)
# BACKEND_URL=https://your-backend.onrender.com
# AI_PIPELINE_URL=https://your-ai-pipeline.onrender.com
# FRONTEND_URL=https://your-frontend.vercel.app

# ============================================
# Hardware Configuration
# ============================================

# Webcam index (0 = default webcam)
WEBCAM_INDEX=0
WEBCAM_AUTO_INTERVAL_SECONDS=0
WEBCAM_AUTO_START=false

# Raspberry Pi settings (uncomment if deploying to Pi)
# PI_MODE=true
# BATCH_SIZE=1
# CONF_THRESHOLD=0.5

# Debugger paths (optional)
# DEBUGGER_SAMPLE_DOCS_DIR=
# DEBUGGER_AI_PIPELINE_WORKDIR=
# DEBUGGER_AI_PIPELINE_PYTHON=
# DEBUGGER_AGENTIC_RUNNER=

# ============================================
# Feature Flags
# ============================================

# Enable/disable modules
ENABLE_YOLO=true
ENABLE_OCR=true
ENABLE_LLM=true
ENABLE_TTS=true
AGENTIC_USE_YOLO=true
AGENTIC_ENABLE_SELECTION=true
AGENTIC_ENABLE_TTS=true

# TTS settings
TTS_PROVIDER=vieneu
# Options: vieneu (Vietnamese local TTS), gtts (online), pyttsx3 (offline)

# LLM settings
LLM_PROVIDER=alibaba
# Options: alibaba, dashscope, gemini, ollama
LLM_API_KEY=
LLM_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1
LLM_ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic
LLM_MODEL=qwen3.5-plus
# Visual-capable models:
# - qwen3.5-plus
# - kimi-k2.5
LLM_TIMEOUT_SECONDS=60

# ============================================
# Logging
# ============================================

LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
